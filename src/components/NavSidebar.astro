---
import type { NavGroup } from '../types'
import SearchForm from './SearchForm.astro'
import SiteFooter from './SiteFooter.astro'

const {
  currentPathname,
  googleSearchSite,
  linksPathname,
  navGroups = [],
  searchAction,
  showLinks,
  showTags,
  siteUrl,
  tagsPathname,
} = Astro.props as {
  currentPathname: string
  googleSearchSite?: string
  linksPathname: string
  navGroups?: NavGroup[]
  searchAction: string
  showLinks?: boolean
  showTags?: boolean
  siteUrl: string
  tagsPathname: string
}

// --- sidebar layout ---
const asideClass =
  'relative grid grid-cols-1 items-start overflow-y-visible md:block md:max-h-[100svh] md:overflow-y-auto'

// --- search ---
const searchWrapClass = 'mb-5 md:mb-4'

// --- nav ---
const navClass = 'relative z-10 col-start-1 row-start-1 min-w-0 pr-8 md:block md:pr-0'
const listClass = 'm-0 list-none flex-wrap gap-0 pl-0 pt-0 md:block'
const itemClass = 'flex items-center text-sm leading-none'

// clean link (no card bg)
const linkClass =
  'group/link flex items-center gap-1.5 rounded-sm px-2 py-1 text-sm leading-6 text-muted/80 no-underline transition-[color,background-color] duration-150 ease-in-out hover:bg-white/40 hover:text-heading hover:no-underline'
const currentLinkClass = 'font-medium text-heading bg-white/50'

// external arrow
const extArrowClass = 'h-2.5 w-2.5 text-muted/40 transition-colors duration-150 group-hover/link:text-muted/70'

// divider between primary and external links
const dividerClass = 'mx-2 my-2 h-px bg-line/40 md:my-1.5'

// --- footer ---
const footerWrapClass = 'mt-6 md:mt-5'

const primaryNavItems = [
  showTags && {
    href: `${siteUrl}tags`,
    pathname: tagsPathname,
    title: 'Tags',
  },
  showLinks && {
    href: `${siteUrl}links`,
    pathname: linksPathname,
    title: 'Links',
  },
].filter((item): item is { href: string; pathname: string; title: string } => Boolean(item))
---

<div class={asideClass}>
  <div class={searchWrapClass}>
    <SearchForm action={searchAction} googleSearchSite={googleSearchSite} />
  </div>

  <nav class={navClass} aria-label="Primary navigation">
    <ul class={listClass}>
      {
        primaryNavItems.map((nav) => (
          <li class={itemClass}>
            <a
              href={nav.href}
              title={nav.title}
              class:list={[
                linkClass,
                currentPathname === nav.pathname && currentLinkClass,
              ]}
            >
              <span class="inline-block h-1.5 w-1.5 rounded-full transition-colors duration-150" class:list={[
                currentPathname === nav.pathname ? 'bg-heading' : 'bg-transparent',
              ]} />
              {nav.title}
            </a>
          </li>
        ))
      }

      {primaryNavItems.length > 0 && navGroups.length > 0 && <li class={dividerClass} aria-hidden="true" />}

      {
        navGroups.map((group) => (
          <Fragment>
            {group.items.map((nav) => (
              <li class={itemClass}>
                <a
                  href={nav.href}
                  title={nav.title}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={linkClass}
                >
                  <span class="inline-block h-1.5 w-1.5 rounded-full bg-transparent" />
                  {nav.title}
                  <svg class={extArrowClass} viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path
                      d="M4.5 11.5 11.5 4.5m0 0v6.5m0-6.5H5"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.4"
                    />
                  </svg>
                </a>
              </li>
            ))}
          </Fragment>
        ))
      }
    </ul>
  </nav>

  <div class={footerWrapClass}>
    <SiteFooter />
  </div>
</div>
