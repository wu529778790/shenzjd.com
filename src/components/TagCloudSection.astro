---
import type { TagCloudItem } from '../types'
import { tagChipLinkClass } from '../lib/style-classes'

const { id, title, items } = Astro.props as {
  id?: string
  title: string
  items: TagCloudItem[]
}
const titleId = id ?? `${title.toLowerCase().replace(/[^a-z0-9]+/g, '-') || 'section'}-title`

const sectionTitleClass = 'm-0 px-2.5 text-base font-semibold leading-none text-heading'
const tagCloudClass =
  'mt-4 mb-0 columns-1 gap-5 list-none pl-0 leading-normal md:columns-2 md:gap-10 md:[column-rule:1px_solid_var(--color-line)]'
const tagCloudItemClass = 'mb-2 block break-inside-avoid'
const tagLinkClass = tagChipLinkClass
---

<section aria-labelledby={titleId}>
  <h1 id={titleId} class={sectionTitleClass}>{title}</h1>

  <ul class={tagCloudClass} role="list">
    {
      items.map((item) => (
        <li class={tagCloudItemClass}>
          <a
            href={item.href}
            class={tagLinkClass}
            title={item.title ?? item.label}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</section>
