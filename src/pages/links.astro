---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import TagCloudSection from '../components/TagCloudSection.astro'
import { getChannelInfo } from '../lib/telegram'
import { getEnv, parseDelimitedItems } from '../lib/env'

const channel = await getChannelInfo(Astro)
const pageSeo = { title: 'Links' }
const links = parseDelimitedItems(getEnv(import.meta.env, Astro, 'LINKS'))

if (!links.length) {
  return Astro.redirect('/')
}

const items = links.map((link) => ({
  href: link.href,
  label: link.title,
  title: link.title,
  external: true,
}))
---

<Layout channel={channel} seo={pageSeo}>
  <Header channel={channel} />

  <TagCloudSection id="links" title="Links" items={items} />
</Layout>
