# Telegram 频道用户名（不带 @）
CHANNEL=shenzjd_com

# 语言与时区
LOCALE=zh-CN
TIMEZONE=Asia/Shanghai

# 静态资源代理前缀（GFW 绕行，必须启用 /static/）
STATIC_PROXY=/static/

# Telegram 主机名（服务端抓取用，需服务端可出墙访问）
TELEGRAM_HOST=t.me

# 站点 URL（用于 RSS / Sitemap / OG）
SITE_URL=https://shenzjd.com

# 评论与反应（reactions 原生支持；comments 为可选 Telegram 评论组件）
COMMENTS=true
REACTIONS=true

# 隐藏频道描述
HIDE_DESCRIPTION=false

# 标签 / 链接 / 导航（分号分隔；导航格式 标题,URL;标题,URL）
# 导航默认已内置为「社交平台 / 在线服务」两组（见 src/lib/nav.ts），无需设置即可生效；
# 如需自定义，用 NAVS 覆盖为扁平列表：标题,URL;标题,URL
TAGS=
LINKS=
NAVS=

# 社交链接
TELEGRAM=shenzjd_com
TWITTER=
GITHUB=shenzjd
DISCORD=
PODCAST=
MASTODON=
BLUESKY=

# SEO
NOFOLLOW=false
NOINDEX=false

# 页头/页脚注入（支持 HTML）
HEADER_INJECT=
FOOTER_INJECT=

# Google 站内搜索（填域名启用，否则用内置搜索）
GOOGLE_SEARCH_SITE=

# RSS 美化
RSS_BEAUTIFY=

# 诊断日志（默认关闭，排查时置 1 即可，零开销）
# DIAG_ACCESS=1   每个入站请求一行：方法、路径、客户端 IP、User-Agent
# DIAG_TELEGRAM=1 Telegram 抓取：缓存 hit/miss、HTTP 状态或错误类型、耗时(ms)
DIAG_ACCESS=
DIAG_TELEGRAM=
DIAG_CACHE_STATS=

# Telegram HTML 缓存最大条目数（LRU 淘汰）
# 单页约 200-500KB，2048 条约占用 400MB-1GB 堆内存
TELEGRAM_HTML_CACHE_MAX=2048
