## Telegram Channel Username, must be configured
CHANNEL=shenzjd_com

## Language and timezone settings
LOCALE=zh-CN
TIMEZONE=Asia/Shanghai

## GitHub username (nav icon)
GITHUB=

## Static resource proxy prefix
STATIC_PROXY=/static/

## Telegram host name
TELEGRAM_HOST=t.me

## Comments and reactions
COMMENTS=true
REACTIONS=true

## Hide Telegram channel description
HIDE_DESCRIPTION=false

## Site URL (for RSS/Sitemap)
SITE_URL=

## Tags, Links, Navigation (semicolon-delimited)
TAGS=
LINKS=
NAVS=

## Header and footer code injection, supports HTML
HEADER_INJECT=
FOOTER_INJECT=

## Google Site Search (set domain to enable)
GOOGLE_SEARCH_SITE=

## Promotional sidebar cards (title|description|url;title|description|url)
PROMOS=
