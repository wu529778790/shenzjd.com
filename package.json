{
  "name": "shenzjd-com",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "test -d .git && simple-git-hooks || true"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@iconify-json/ri": "^1.2.10",
    "astro-icon": "^1.1.5",
    "cheerio": "1.0.0-rc.12",
    "flourite": "^1.3.0",
    "ocache": "^0.1.5",
    "ofetch": "^1.5.1",
    "prismjs": "1.28.0",
    "prismjs-components-importer": "^0.2.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@astrojs/node": "^10.1.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/prismjs": "^1.26.6",
    "astro": "^6.4.6",
    "astro-eslint-parser": "^1.4.0",
    "astro-seo": "^1.1.0",
    "baseline-browser-mapping": "^2.10.36",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.7",
    "prettier-plugin-astro": "^0.14.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "overrides": {
    "path-to-regexp": "6.3.0",
    "semver": "6.3.1",
    "tar": "7.5.16"
  },
  "browserslist": [
    "defaults"
  ]
}
